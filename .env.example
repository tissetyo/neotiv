# Neotiv — Environment Variables

# Database (Railway free tier → easily swap to VPS PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/neotiv

# Redis (Upstash free tier → easily swap to VPS Redis)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=neotiv-dev-secret-change-in-production-min-32-chars

# API URL (all frontends point here)
NEXT_PUBLIC_API_URL=http://localhost:3001

# External APIs (optional - works with mock data without these)
OPENWEATHER_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# File Storage (Cloudflare R2 → easily swap to local/VPS storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=neotiv-uploads
R2_PUBLIC_URL=
